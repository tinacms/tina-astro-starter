---
export const prerender = false;
import BlogPost from '../../layouts/BlogPost.astro';
import BlogBody from '../../components/islands/BlogBody.astro';
import { getBlog } from '../../lib/data';

const slug = (Astro.params.slug ?? '').toString();
const blog = await getBlog(slug, Astro.request);
const data = blog.data?.blog as Record<string, unknown> | undefined;

const layoutProps = {
	title: (data?.title as string) ?? '',
	description: (data?.description as string) ?? '',
	pubDate: data?.pubDate ? new Date(data.pubDate as string) : new Date(),
	updatedDate: data?.updatedDate ? new Date(data.updatedDate as string) : undefined,
	heroImage: (data?.heroImage as string | null | undefined) ?? null,
	forms: [{ id: blog.id, query: blog.query, variables: blog.variables, data: blog.data as unknown as object }],
};
---

<BlogPost {...layoutProps}>
	<article data-tina-island={`/tina-island/blog?slug=${encodeURIComponent(slug)}`}>
		<BlogBody data={data} />
	</article>
</BlogPost>
