---
import Base from './Base.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string | null;
}

const { title, description, heroImage } = Astro.props;
---

<Base title={title} description={description} image={heroImage ?? undefined}>
	<slot />
</Base>
