---
import { tinaField } from "@tinacms/astro/tina-field";
import type { ConfigQuery } from "../../tina/__generated__/types";
import HeaderLink from "./HeaderLink.astro";
import IconLink from "./IconLink.astro";

interface Props {
	config?: ConfigQuery["config"] | null;
}

const { config } = Astro.props;
const seo = config?.seo ?? null;
const nav = (config?.nav ?? []).filter((item) => item !== null);
const contactLinks = (config?.contactLinks ?? []).filter((item) => item !== null);
---

<header>
	<nav>
		<h2>
			<a href="/" class="nav-header">
				{seo?.logo && <img src={seo.logo} alt="Logo" width="50" height="50" data-tina-field={tinaField(seo, "logo")} />}
				<span data-tina-field={seo ? tinaField(seo, "title") : undefined}>{seo?.title}</span>
			</a>
		</h2>
		<div class="internal-links">
			{nav.map((item) => (
				<HeaderLink href={item.link} data-tina-field={tinaField(item, "title")}>{item.title}</HeaderLink>
			))}
		</div>
		<div class="social-links">
			{contactLinks.map((link) => (
				<IconLink
					title={link.title}
					link={link.link}
					icon={link.icon}
					data-tina-field={tinaField(link, "title")}
				/>
			))}
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
