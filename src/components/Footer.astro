---
import { tinaField } from "@tinacms/astro/tina-field";
import type { CmsConfig, CmsConfigContactLink } from '../lib/data';
import IconLink from "./IconLink.astro";
import Starfield from './space/Starfield.astro';

interface Props {
	config?: CmsConfig | null;
}

const { config } = Astro.props;
const seo = config?.seo ?? null;
const contactLinks = (config?.contactLinks ?? []).filter(
	(item): item is CmsConfigContactLink => item !== null,
);
const today = new Date();
---
<footer class="border-t bg-background py-12 text-center text-sm text-muted-foreground relative overflow-hidden">
	{config?.footerStarfield !== false && <Starfield count={50} class="text-foreground/15" />}
	<div class="relative flex flex-col items-center gap-6">
		{contactLinks.length > 0 && (
			<div class="flex justify-center gap-4">
				{contactLinks.map((link) => (
					<IconLink
						title={link.title}
						link={link.link}
						icon={link.icon}
						data-tina-field={tinaField(link, "title")}
					/>
				))}
			</div>
		)}
		<p>
			&copy; {today.getFullYear()}
			<span data-tina-field={seo ? tinaField(seo, "siteOwner") : undefined}>{seo?.siteOwner}</span>. All rights reserved.
		</p>
		<a
			href="https://tina.io"
			target="_blank"
			rel="noopener noreferrer"
			class="group inline-flex items-center gap-2.5 rounded-full border bg-card/60 py-1.5 pl-1.5 pr-4 text-xs font-medium text-muted-foreground shadow-xs transition-colors duration-200 hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
		>
			<span class="flex size-6 items-center justify-center rounded-full bg-primary transition-transform duration-300 group-hover:scale-105">
				<img src="/llama.svg" alt="" aria-hidden="true" class="size-3.5" />
			</span>
			<span>Powered by <span class="font-semibold text-foreground">TinaCMS</span></span>
		</a>
	</div>
</footer>
