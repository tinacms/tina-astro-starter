---
import { tinaField } from '@tinacms/astro/tina-field';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import Aurora from '../space/Aurora.astro';
import Starfield from '../space/Starfield.astro';
import LlamaNaut from '../space/LlamaNaut.astro';
const { data } = Astro.props;
const actions = (data.actions ?? []).filter(Boolean);
---
<Section background={data.background} class="relative overflow-hidden">
	<Aurora />
	<Starfield count={70} class="text-foreground/20" />
	<div class="relative text-center sm:mx-auto lg:mr-auto">
		<LlamaNaut class="mx-auto mb-6 size-28 md:size-32" />
		{data.headline && <h1 data-tina-field={tinaField(data, 'headline')} class="mt-8 text-balance text-6xl md:text-7xl xl:text-[5.25rem] font-semibold tracking-tight">{data.headline}</h1>}
		{data.tagline && <p data-tina-field={tinaField(data, 'tagline')} class="mx-auto mt-8 max-w-2xl text-balance text-lg text-muted-foreground">{data.tagline}</p>}
		{actions.length > 0 && (
			<div class="mt-12 flex flex-col items-center justify-center gap-2 md:flex-row">
				{actions.map((action: any) => (
					<div data-tina-field={tinaField(action)} class="bg-foreground/10 rounded-2xl border p-0.5">
						<Button href={action.link} size="lg" variant={action.type === 'link' ? 'ghost' : 'default'} class="rounded-xl px-5 text-base">
							{action.icon && <Icon name={action.icon} class="size-4" />}
							<span class="text-nowrap">{action.label}</span>
						</Button>
					</div>
				))}
			</div>
		)}
	</div>
	{data.image?.src && (
		<div data-tina-field={tinaField(data, 'image')} class="relative mt-8 overflow-hidden px-2 sm:mt-12 md:mt-20">
			<div class="bg-background relative mx-auto max-w-6xl overflow-hidden rounded-2xl border p-4 shadow-lg ring-1 ring-background">
				<img src={data.image.src} alt={data.image.alt ?? ''} width="3000" height="1600" class="rounded-2xl border border-border/25 aspect-[15/8] object-cover w-full h-auto" />
			</div>
		</div>
	)}
</Section>
